{
  "framework": null,
  "installCommand": "npm install",
  "buildCommand": "npm run vercel-build",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/publish",
      "schedule": "0 15 * * *"
    }
  ]
}
